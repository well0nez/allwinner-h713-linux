+
+static void __init sun50i_h713_ccu_init(struct device_node *node)
+{
+	void __iomem *reg;
+	int i;
+	u32 val;
+
+	reg = of_io_request_and_map(node, 0, of_node_full_name(node));
+	if (IS_ERR(reg)) {
+		pr_err("%pOF: Could not map CCU registers\n", node);
+		return;
+	}
+
+	/* DIAGNOSTIC: Check MIPS flag before ANY register writes */
+	{
+		void __iomem *shmem = ioremap(0x4E300000, 0x5000);
+		if (shmem) {
+			pr_info("MIPS_DIAG[ccu_pre]: MIPS=0x%x ARM=0x%x\n",
+				readl(shmem + 19680), readl(shmem + 19676));
+			iounmap(shmem);
+		}
+	}
+
+	for (i = 0; i < ARRAY_SIZE(pll_regs); i++) {
+		val = readl(reg + pll_regs[i]);
+		val |= BIT(29);
+		writel(val, reg + pll_regs[i]);
+	}
+
+	for (i = 0; i < ARRAY_SIZE(pll_video_regs); i++) {
+		val = readl(reg + pll_video_regs[i]);
+		val &= ~BIT(0);
+		writel(val, reg + pll_video_regs[i]);
+	}
+
+	for (i = 0; i < ARRAY_SIZE(usb_clk_regs); i++) {
+		val = readl(reg + usb_clk_regs[i]);
+		val &= ~GENMASK(25, 24);
+		writel(val, reg + usb_clk_regs[i]);
+	}
+
+	val = readl(reg + SUN50I_H713_PLL_AUDIO_REG);
+	val &= ~(GENMASK(21, 16) | BIT(0));
+	val |= (11 << 16) | BIT(0);
+	writel(val, reg + SUN50I_H713_PLL_AUDIO_REG);
+
+	of_sunxi_ccu_probe(node, reg, &sun50i_h713_ccu_desc);
+
+}
+
+CLK_OF_DECLARE(sun50i_h713_ccu, "allwinner,sun50i-h713-ccu",
+	       sun50i_h713_ccu_init);
