+/* DIAGNOSTIC: Monitor MIPS flag at multiple early boot stages */
+#include <linux/io.h>
+static void __init mips_flag_snapshot(const char *tag)
+{
+	void __iomem *shmem = ioremap(0x4E300000, 0x5000);
+	if (shmem) {
+		u32 arm = readl(shmem + 19676);
+		u32 mips = readl(shmem + 19680);
+		u32 mag = readl(shmem + 0x90);
+		pr_info("MIPS_DIAG[%s]: ARM=0x%x MIPS=0x%x magic=0x%x\n",
+			tag, arm, mips, mag);
+		iounmap(shmem);
+	}
+}
+static int __init mips_flag_postcore(void) { mips_flag_snapshot("postcore"); return 0; }
+static int __init mips_flag_arch(void)     { mips_flag_snapshot("arch"); return 0; }
+static int __init mips_flag_subsys(void)   { mips_flag_snapshot("subsys"); return 0; }
+static int __init mips_flag_fs(void)       { mips_flag_snapshot("fs"); return 0; }
+static int __init mips_flag_device(void)   { mips_flag_snapshot("device"); return 0; }
+static int __init mips_flag_late(void)     { mips_flag_snapshot("late"); return 0; }
+postcore_initcall(mips_flag_postcore);
+arch_initcall(mips_flag_arch);
+subsys_initcall(mips_flag_subsys);
+fs_initcall(mips_flag_fs);
+device_initcall(mips_flag_device);
+late_initcall(mips_flag_late);
