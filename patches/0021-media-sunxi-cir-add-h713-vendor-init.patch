--- a/drivers/media/rc/sunxi-cir.c	2025-09-11 17:23:23.000000000 +0200
+++ b/drivers/media/rc/sunxi-cir.c	2026-04-05 20:31:40.397905920 +0200
@@ -63,6 +63,7 @@
 #define REG_RXSTA_GET_AC(val) (((val) >> 8) & (ir->fifo_size * 2 - 1))
 /* Clear all interrupt status value */
 #define REG_RXSTA_CLEARALL    0xff
+#define REG_RXSTA_CLEARALL_H713 0xef
 
 /* IR Sample Config */
 #define SUNXI_IR_CIR_REG      0x34
@@ -96,6 +97,7 @@
 	struct clk      *apb_clk;
 	struct reset_control *rst;
 	const char      *map_name;
+	bool		is_h713_vendor_init;
 };
 
 static irqreturn_t sunxi_ir_irq(int irqno, void *dev_id)
@@ -199,24 +201,54 @@
 	/* Set noise threshold and idle threshold */
 	sunxi_ir_set_timeout(ir->rc, ir->rc->timeout);
 
+	/* H713 vendor-like sample config tuning (IDA-correlated) */
+	if (ir->is_h713_vendor_init) {
+		/* NTHR=8, ITHR=0xb2 plus vendor extra bitfields */
+		writel(0x00200b2a, ir->base + SUNXI_IR_CIR_REG);
+	}
+
 	/* Invert Input Signal */
 	writel(REG_RXCTL_RPPI, ir->base + SUNXI_IR_RXCTL_REG);
 
+	if (ir->is_h713_vendor_init)
+		writel(0x4, ir->base + SUNXI_IR_RXCTL_REG);
+
 	/* Clear All Rx Interrupt Status */
-	writel(REG_RXSTA_CLEARALL, ir->base + SUNXI_IR_RXSTA_REG);
+	if (ir->is_h713_vendor_init)
+		writel(REG_RXSTA_CLEARALL_H713, ir->base + SUNXI_IR_RXSTA_REG);
+	else
+		writel(REG_RXSTA_CLEARALL, ir->base + SUNXI_IR_RXSTA_REG);
 
 	/*
 	 * Enable IRQ on overflow, packet end, FIFO available with trigger
 	 * level
 	 */
-	writel(REG_RXINT_ROI_EN | REG_RXINT_RPEI_EN |
-	       REG_RXINT_RAI_EN | REG_RXINT_RAL(ir->fifo_size / 2 - 1),
-	       ir->base + SUNXI_IR_RXINT_REG);
+	if (ir->is_h713_vendor_init)
+		writel(0x1313, ir->base + SUNXI_IR_RXINT_REG);
+	else
+		writel(REG_RXINT_ROI_EN | REG_RXINT_RPEI_EN |
+		       REG_RXINT_RAI_EN | REG_RXINT_RAL(ir->fifo_size / 2 - 1),
+		       ir->base + SUNXI_IR_RXINT_REG);
 
 	/* Enable IR Module */
 	tmp = readl(ir->base + SUNXI_IR_CTL_REG);
+	if (ir->is_h713_vendor_init) {
+		tmp |= 0xc0;
+		writel(tmp, ir->base + SUNXI_IR_CTL_REG);
+		tmp = readl(ir->base + SUNXI_IR_CTL_REG);
+	}
 	writel(tmp | REG_CTL_GEN | REG_CTL_RXEN, ir->base + SUNXI_IR_CTL_REG);
 
+	if (ir->is_h713_vendor_init) {
+		dev_info(dev,
+			 "h713-ir regs ctl=%#x rxctl=%#x rxint=%#x rxsta=%#x cir=%#x\n",
+			 readl(ir->base + SUNXI_IR_CTL_REG),
+			 readl(ir->base + SUNXI_IR_RXCTL_REG),
+			 readl(ir->base + SUNXI_IR_RXINT_REG),
+			 readl(ir->base + SUNXI_IR_RXSTA_REG),
+			 readl(ir->base + SUNXI_IR_CIR_REG));
+	}
+
 	return 0;
 
 exit_disable_apb_clk:
@@ -250,6 +282,7 @@
 
 static SIMPLE_DEV_PM_OPS(sunxi_ir_pm_ops, sunxi_ir_suspend, sunxi_ir_resume);
 
