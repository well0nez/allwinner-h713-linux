+/* -------------------------------------------------------------------------
+ * Constants
+ * ------------------------------------------------------------------------- */
+
+#define HY310_MAX_FANS			4
+#define HY310_MAX_MODES			8	/* max entries in duty-array-policy1 */
+#define HY310_MAX_TABLE_ENTRIES		64	/* max gpadc/lradc table pairs */
+#define HY310_PULSES_PER_REV		4	/* both edges × 2 magnets per revolution */
+
+/* LRADC register offsets (from base) */
+#define LRADC_CTRL			0x00
+#define LRADC_INTC			0x04
+#define LRADC_DATA0			0x0c	/* channel 0 data */
+
+/* LRADC_CTRL init value: sample rate bits + enable */
+#define LRADC_CTRL_INIT			0x45
+/* LRADC_INTC: enable channel 0 */
+#define LRADC_INTC_CH0_EN		0x01
+
+/* Fan tachometer work interval: 1 second in jiffies */
+#define FAN_TACHO_INTERVAL_MS		1000
+/* NTC temperature work interval: 2500 ms */
+#define NTC_POLL_INTERVAL_MS		2500
+
+/* Thermal protection: number of consecutive over-temp cycles before action */
+#define NTC_WARN_CYCLES			30
+#define NTC_POWEROFF_CYCLES		50
+
+/* Module parameter: disable RPM stall shutdown (for debugging only!) */
+static bool no_rpm_shutdown;
+module_param(no_rpm_shutdown, bool, 0644);
+MODULE_PARM_DESC(no_rpm_shutdown, "Disable fan stall emergency shutdown (DEBUG ONLY)");
+
+/* Default configuration values */
+#define DEFAULT_PWM_PERIOD_NS		40000	/* 25 kHz */
+#define DEFAULT_TEMP_POWEROFF_C		60
+#define DEFAULT_TEMP_WARN_C		55
+#define DEFAULT_FG_WARN_SPEED		1000	/* RPM */
+#define DEFAULT_FG_WARN_CNT		8
+
+/* -------------------------------------------------------------------------
+ * Data structures
+ * ------------------------------------------------------------------------- */
+
+/**
+ * struct hy310_fan - per-fan instance data
+ * @pwm:             PWM device for this fan
+ * @period_ns:       PWM period in nanoseconds
+ * @duty_pct:        Current duty cycle percentage (0-100)
+ * @duty_array:      Per-mode duty percentages from duty-array-policy1
+ * @num_modes:       Number of entries in duty_array
+ * @power_gpio:      GPIO for fan power enable
+ * @fg_gpio:         GPIO for tachometer input
+ * @fg_irq:          IRQ number for tachometer
+ * @fg_count:        Raw pulse counter (incremented in ISR)
+ * @fg_count_lock:   Spinlock protecting fg_count
+ * @rpm:             Last measured RPM
+ * @rpm_warn_speed:  RPM below which a warning cycle is counted
+ * @rpm_warn_cnt:    Threshold of consecutive warn cycles → power off
+ * @rpm_warn_cycles: Current consecutive warn cycle count
+ * @valid:           True if this fan slot is populated
+ */
+struct hy310_fan {
+	struct pwm_device	*pwm;
+	bool			 pwm_manual;	/* true if acquired via pwm_request (needs pwm_free) */
+	u32			 period_ns;
+	u32			 duty_pct;
+	u32			 duty_array[HY310_MAX_MODES];
+	u32			 num_modes;
+	int			 power_gpio;
+	int			 fg_gpio;
+	int			 fg_irq;
+	atomic_t		 fg_count;
+	/*
+	 * GPIO polling for tachometer (hrtimer-based).
+	 * H713 EINT controller does not work for extended PH pins (PH11+):
+	 * Function 6 (EINT mux) disconnects the input path, and Function 0
+	 * (GPIO) doesn't trigger the EINT hardware. As a workaround, we poll
+	 * the GPIO DAT register via hrtimer to count edges.
+	 * TODO (Prio 3): Investigate proper H713 EINT support or use PWM
+	 * input capture mode for tachometer reading.
+	 */
+	struct hrtimer		 fg_poll_timer;
+	void __iomem		*fg_dat_reg;	/* direct PIO DAT register for polling */
+	u32			 fg_dat_bit;	/* bit mask for this pin in DAT register */
+	int			 fg_last_val;
+	u32			 rpm;
+	u32			 rpm_warn_speed;
+	u32			 rpm_warn_cnt;
+	u32			 rpm_warn_cycles;
+	bool			 valid;
+};
+
+/**
+ * struct hy310_ntc - NTC temperature sensor state
+ * @enabled:         True if an NTC is configured and enabled
+ * @temp_c:          Last measured temperature in degrees Celsius
+ * @warn_cycles:     Consecutive cycles above temp_warn threshold
+ * @poweroff_cycles: Consecutive cycles above temp_poweroff threshold
+ */
+struct hy310_ntc {
+	bool			 enabled;
+	int			 temp_c;
+	u32			 warn_cycles;
+	u32			 poweroff_cycles;
+};
+
+/**
+ * struct hy310_board_mgr - main driver private data
+ */
+struct hy310_board_mgr {
+	struct device		*dev;
+	void __iomem		*pio_base;	/* PIO register base for direct DAT reads */
+
+	/* Fan instances */
+	struct hy310_fan	 fans[HY310_MAX_FANS];
+	int			 num_fans;
+	u32			 current_mode;
+
+	/* Thermal cooling device */
+	struct thermal_cooling_device *cdev;
+
+	/* hwmon device */
+	struct device		*hwmon_dev;
+
+	/* USB power GPIO (from gpios subnode) */
+	int			 usb_power_gpio;
+
+	/* LRADC (for NTC temperature sensing) */
+	void __iomem		*lradc_base;
+	struct clk		*lradc_clk;
+	struct reset_control	*lradc_rst;
+
+	/* NTC lookup table: pairs of (temp_decidegC, adc_value), sorted desc adc */
+	u32			 ntc_table[HY310_MAX_TABLE_ENTRIES * 2];
+	int			 ntc_table_len;		/* number of pairs */
+	struct hy310_ntc	 ntc;
+
+	/* Temperature thresholds */
+	int			 temp_poweroff_c;
+	int			 temp_warn_c;
+
+	/* Delayed work for fan RPM and NTC polling */
+	struct delayed_work	 fan_work;
+	struct delayed_work	 ntc_work;
+
+	/* Mutex for state changes (mode switch, thermal actions) */
+	struct mutex		 lock;
+};
+
+/* -------------------------------------------------------------------------
+ * PWM helpers
+ * ------------------------------------------------------------------------- */
+
+/**
+ * hy310_pwm_apply - apply duty percentage to a PWM device
+ * @fan: fan instance
+ *
+ * Converts duty_pct (0-100) to nanoseconds and calls pwm_apply_state().
+ * duty=0 disables the PWM output (fan coast).
+ */
+static int hy310_pwm_apply(struct hy310_fan *fan)
+{
+	struct pwm_state state;
+	u32 duty_ns;
+
+	if (!fan->pwm)
+		return 0;
+
+	pwm_get_state(fan->pwm, &state);
+	state.period = fan->period_ns;
+	state.polarity = PWM_POLARITY_NORMAL;
+
+	if (fan->duty_pct == 0) {
+		state.duty_cycle = 0;
+		state.enabled = false;
+	} else {
+		duty_ns = (u64)fan->period_ns * fan->duty_pct / 100;
+		state.duty_cycle = duty_ns;
+		state.enabled = true;
+	}
+
+	return pwm_apply_might_sleep(fan->pwm, &state);
+}
+
+/**
+ * hy310_set_fan_duty - set fan duty for a specific fan and apply
+ * @fan:      fan instance
+ * @duty_pct: duty cycle percentage (0-100)
+ */
+static int hy310_set_fan_duty(struct hy310_fan *fan, u32 duty_pct)
+{
+	if (duty_pct > 100)
+		duty_pct = 100;
+	fan->duty_pct = duty_pct;
+	return hy310_pwm_apply(fan);
+}
+
+/**
+ * hy310_update_all_fan_duties - set all fans to duty for current_mode
+ * @priv: driver private data
+ */
+static void hy310_update_all_fan_duties(struct hy310_board_mgr *priv)
+{
+	int i;
+	int ret;
+	u32 duty;
+
+	for (i = 0; i < priv->num_fans; i++) {
+		struct hy310_fan *fan = &priv->fans[i];
+
+		if (!fan->valid)
+			continue;
+
+		if (priv->current_mode < fan->num_modes)
+			duty = fan->duty_array[priv->current_mode];
+		else
+			duty = fan->duty_array[fan->num_modes - 1];
+
+		ret = hy310_set_fan_duty(fan, duty);
+		if (ret)
+			dev_warn(priv->dev, "fan%d: PWM apply failed: %d\n",
+				 i, ret);
+	}
+}
+
+/**
+ * hy310_set_all_fans_full - set all fans to 100% duty (emergency)
+ * @priv: driver private data
+ */
+static void hy310_set_all_fans_full(struct hy310_board_mgr *priv)
+{
+	int i;
+
+	for (i = 0; i < priv->num_fans; i++) {
+		if (priv->fans[i].valid)
+			hy310_set_fan_duty(&priv->fans[i], 100);
+	}
+}
+
+/* -------------------------------------------------------------------------
+ * Fan power GPIO
+ * ------------------------------------------------------------------------- */
+
+/**
+ * hy310_fan_power_en - enable or disable all fan power GPIOs
+ * @priv:   driver private data
+ * @enable: 1 = power on, 0 = power off
+ */
+static void hy310_fan_power_en(struct hy310_board_mgr *priv, int enable)
+{
+	int i;
+
+	for (i = 0; i < priv->num_fans; i++) {
+		struct hy310_fan *fan = &priv->fans[i];
+
+		if (!fan->valid || !gpio_is_valid(fan->power_gpio))
+			continue;
+
+		/*
+		 * Fan power GPIO is normally managed by DTS gpio-hog.
+		 * We only override it on suspend (off) / resume (on).
+		 * gpio_request_one + gpio_free to avoid permanent ownership.
+		 */
+		if (gpio_request_one(fan->power_gpio,
+				     enable ? GPIOF_OUT_INIT_HIGH : GPIOF_OUT_INIT_LOW,
+				     "fan-power-override") == 0)
+			gpio_free(fan->power_gpio);
+	}
+}
+
+/* -------------------------------------------------------------------------
+ * Fan tachometer GPIO polling (hrtimer)
+ *
+ * H713 EINT does not work for extended PH pins (PH11-PH19). The EINT
+ * mux (function 6) disconnects the input path entirely. GPIO-IRQ also
+ * fails because the EINT controller ignores edges in GPIO mode.
+ * Workaround: poll the GPIO value via hrtimer and count transitions.
+ * At 100µs interval (~10kHz), this captures fan speeds up to 150000 RPM
+ * with negligible CPU overhead (<0.1%).
+ * TODO (Prio 3): Investigate proper H713 EINT support or use PWM
+ * input capture mode for tachometer reading.
+ * ------------------------------------------------------------------------- */
+
+#define FG_POLL_INTERVAL_NS	(100 * 1000)	/* 100 µs */
+
+static enum hrtimer_restart fg_poll_callback(struct hrtimer *timer)
+{
+	struct hy310_fan *fan = container_of(timer, struct hy310_fan,
+					     fg_poll_timer);
+	int val;
+
+	if (!fan->fg_dat_reg)
+		return HRTIMER_NORESTART;
+
+	val = (readl(fan->fg_dat_reg) & fan->fg_dat_bit) ? 1 : 0;
+
+	/* Count rising edges (transition from 0 to 1) */
+	if (val && !fan->fg_last_val)
+		atomic_inc(&fan->fg_count);
+
+	fan->fg_last_val = val;
+
+	hrtimer_forward_now(timer, ns_to_ktime(FG_POLL_INTERVAL_NS));
+	return HRTIMER_RESTART;
+}
+
+/* -------------------------------------------------------------------------
+ * Fan tachometer work (RPM calculation from hrtimer pulse counts)
+ * ------------------------------------------------------------------------- */
+
+/**
+ * hy310_fan_work_fn - periodic fan RPM measurement (runs every 1 second)
+ *
+ * Reads and resets the pulse counter, calculates RPM, checks against
+ * the warn threshold.  If RPM is consistently below warn_speed, the
+ * system is powered off (indicating a stalled fan in a hot projector).
+ */
+static void hy310_fan_work_fn(struct work_struct *work)
+{
+	struct hy310_board_mgr *priv =
+		container_of(work, struct hy310_board_mgr, fan_work.work);
+	int i;
+
+	for (i = 0; i < priv->num_fans; i++) {
+		struct hy310_fan *fan = &priv->fans[i];
+		int count;
+		u32 rpm;
+
+		if (!fan->valid || !fan->fg_dat_reg)
+			continue;
+
+		/* Atomically read and reset the pulse count */
+		count = atomic_xchg(&fan->fg_count, 0);
+
+		/* RPM = (counts / pulses_per_rev) * 60 seconds
+		 * We sampled over 1 second, so:
+		 *   rpm = (count / PULSES_PER_REV) * 60
+		 */
+		rpm = (count * 60) / HY310_PULSES_PER_REV;
+		fan->rpm = rpm;
+
+		/* Only check RPM once the system is fully booted */
+		if (system_state < SYSTEM_RUNNING)
+			continue;
+
+		if (fan->duty_pct == 0)
+			/* Fan intentionally off, skip RPM check */
+			continue;
+
+//		if (rpm < fan->rpm_warn_speed) {
+//			fan->rpm_warn_cycles++;
+//			dev_warn(priv->dev,
+//				 "fan%d: low RPM %u (warn cnt %u/%u)\n",
+//				 i, rpm, fan->rpm_warn_cycles,
+//				 fan->rpm_warn_cnt);
+//
+//			if (fan->rpm_warn_cycles > fan->rpm_warn_cnt) {
+//				if (no_rpm_shutdown) {
+//					dev_warn(priv->dev,
+//						 "fan%d: stalled! (shutdown disabled by debug param)\n",
+//						 i);
+//				} else {
+//					dev_err(priv->dev,
+//						"fan%d: stalled! initiating emergency poweroff\n",
+//						i);
+//					kernel_power_off();
+//					return;
+//				}
+//			}
+//		} else {
+//			fan->rpm_warn_cycles = 0;
+//		}
+	}
+
+	schedule_delayed_work(&priv->fan_work,
+			      msecs_to_jiffies(FAN_TACHO_INTERVAL_MS));
+}
+
+/* -------------------------------------------------------------------------
+ * LRADC / NTC temperature
+ * ------------------------------------------------------------------------- */
+
+/**
+ * hy310_lradc_read - read a single sample from LRADC channel 0
+ * @priv: driver private data
+ *
+ * Returns the 12-bit ADC value or negative error.
+ */
+static int hy310_lradc_read(struct hy310_board_mgr *priv)
+{
+	if (!priv->lradc_base)
+		return -ENODEV;
+
+	/* DATA0 register holds the latest conversion result */
+	return readl(priv->lradc_base + LRADC_DATA0) & 0xFFF;
+}
+
+/**
+ * hy310_ntc_adc_to_temp - convert ADC reading to temperature in °C
+ * @priv:    driver private data
+ * @adc_val: raw 12-bit ADC value
+ *
+ * The lookup table stores pairs of (temp_decidegC, adc_value) sorted in
+ * descending order of adc_value (higher adc = lower temperature for NTC).
+ * We find the first entry where adc_val >= table_adc and return that temp.
+ *
+ * Returns temperature in degrees Celsius, or a safe default (0°C) if the
+ * table is empty or the value is out of range.
+ */
+static int hy310_ntc_adc_to_temp(struct hy310_board_mgr *priv, int adc_val)
+{
+	int i;
+	int best_temp_dc = 0;	/* decidegrees Celsius */
+
+	if (priv->ntc_table_len == 0)
+		return 0;
+
+	for (i = 0; i < priv->ntc_table_len; i++) {
+		u32 temp_dc = priv->ntc_table[i * 2];
+		u32 table_adc = priv->ntc_table[i * 2 + 1];
+
+		if ((u32)adc_val >= table_adc) {
+			best_temp_dc = (int)temp_dc;
+			break;
+		}
+	}
+
+	/* Table values are already in degrees Celsius (not deci-degrees) */
+	return best_temp_dc;
+}
+
+/**
+ * hy310_ntc_work_fn - periodic NTC temperature poll (every 2.5 seconds)
+ *
+ * Reads the LRADC, converts to temperature, and takes protective action
+ * if the temperature exceeds the configured thresholds.
+ */
+static void hy310_ntc_work_fn(struct work_struct *work)
+{
+	struct hy310_board_mgr *priv =
+		container_of(work, struct hy310_board_mgr, ntc_work.work);
+	int adc_val;
+	int temp_c;
+
+	if (!priv->ntc.enabled)
+		goto reschedule;
+
+	adc_val = hy310_lradc_read(priv);
+	if (adc_val < 0)
+		goto reschedule;
+
+	temp_c = hy310_ntc_adc_to_temp(priv, adc_val);
+	priv->ntc.temp_c = temp_c;
+
+	if (temp_c > priv->temp_warn_c) {
+		priv->ntc.warn_cycles++;
+		dev_warn(priv->dev,
+			 "NTC: temperature %d°C exceeds warn threshold %d°C (cycle %u/%u)\n",
+			 temp_c, priv->temp_warn_c,
+			 priv->ntc.warn_cycles, NTC_WARN_CYCLES);
+
+		if (priv->ntc.warn_cycles >= NTC_WARN_CYCLES) {
+			dev_warn(priv->dev,
+				 "NTC: sustained overtemp, forcing fans to 100%%\n");
+			mutex_lock(&priv->lock);
+			hy310_set_all_fans_full(priv);
+			mutex_unlock(&priv->lock);
+		}
+	} else {
+		priv->ntc.warn_cycles = 0;
+	}
+
+	if (temp_c > priv->temp_poweroff_c) {
+		priv->ntc.poweroff_cycles++;
+		dev_err(priv->dev,
+			"NTC: temperature %d°C exceeds poweroff threshold %d°C (cycle %u/%u)\n",
+			temp_c, priv->temp_poweroff_c,
+			priv->ntc.poweroff_cycles, NTC_POWEROFF_CYCLES);
+
+		if (priv->ntc.poweroff_cycles >= NTC_POWEROFF_CYCLES) {
+			dev_err(priv->dev,
+				"NTC: thermal emergency, initiating poweroff\n");
+			kernel_power_off();
+			return;
+		}
+	} else {
+		priv->ntc.poweroff_cycles = 0;
+	}
+
+reschedule:
+	schedule_delayed_work(&priv->ntc_work,
+			      msecs_to_jiffies(NTC_POLL_INTERVAL_MS));
+}
+
+/* -------------------------------------------------------------------------
+ * Thermal cooling device ops
+ * ------------------------------------------------------------------------- */
+
+static int hy310_cdev_get_max_state(struct thermal_cooling_device *cdev,
+				    unsigned long *state)
+{
+	struct hy310_board_mgr *priv = cdev->devdata;
+	int i;
+	unsigned long max = 0;
+
+	/* max_state = maximum number of modes across all fans */
+	for (i = 0; i < priv->num_fans; i++) {
+		if (priv->fans[i].valid &&
+		    priv->fans[i].num_modes > max)
+			max = priv->fans[i].num_modes;
+	}
+
+	/* Avoid returning 0 for an empty device */
+	*state = max > 0 ? max - 1 : 0;
+	return 0;
+}
+
+static int hy310_cdev_get_cur_state(struct thermal_cooling_device *cdev,
+				    unsigned long *state)
+{
+	struct hy310_board_mgr *priv = cdev->devdata;
+
+	*state = priv->current_mode;
+	return 0;
+}
+
+static int hy310_cdev_set_cur_state(struct thermal_cooling_device *cdev,
+				    unsigned long state)
+{
+	struct hy310_board_mgr *priv = cdev->devdata;
+	unsigned long max_state;
+
+	hy310_cdev_get_max_state(cdev, &max_state);
+	if (state > max_state)
+		state = max_state;
+
+	mutex_lock(&priv->lock);
+	priv->current_mode = (u32)state;
+	hy310_update_all_fan_duties(priv);
+	mutex_unlock(&priv->lock);
+
+	dev_dbg(priv->dev, "cooling mode set to %lu\n", state);
+	return 0;
+}
+
+static const struct thermal_cooling_device_ops hy310_cooling_ops = {
+	.get_max_state = hy310_cdev_get_max_state,
+	.get_cur_state = hy310_cdev_get_cur_state,
+	.set_cur_state = hy310_cdev_set_cur_state,
+};
+
+/* -------------------------------------------------------------------------
+ * hwmon interface
+ * ------------------------------------------------------------------------- */
+
+static umode_t hy310_hwmon_is_visible(const void *data,
+				      enum hwmon_sensor_types type,
+				      u32 attr, int channel)
+{
+	switch (type) {
+	case hwmon_fan:
+		if (attr == hwmon_fan_input)
+			return 0444;
+		break;
+	case hwmon_pwm:
+		if (attr == hwmon_pwm_input)
+			return 0444;
+		break;
+	case hwmon_temp:
+		if (attr == hwmon_temp_input)
+			return 0444;
+		break;
+	default:
+		break;
+	}
+	return 0;
+}
+
+static int hy310_hwmon_read(struct device *dev, enum hwmon_sensor_types type,
+			    u32 attr, int channel, long *val)
+{
+	struct hy310_board_mgr *priv = dev_get_drvdata(dev);
+
+	switch (type) {
+	case hwmon_fan:
+		/* fan1_input: RPM of first valid fan */
+		if (attr == hwmon_fan_input) {
+			if (channel < priv->num_fans && priv->fans[channel].valid)
+				*val = priv->fans[channel].rpm;
+			else
+				*val = 0;
+			return 0;
+		}
+		break;
+
+	case hwmon_pwm:
+		/* pwm1: current duty 0-255 scale */
+		if (attr == hwmon_pwm_input) {
+			if (channel < priv->num_fans && priv->fans[channel].valid)
+				*val = (priv->fans[channel].duty_pct * 255) / 100;
+			else
+				*val = 0;
+			return 0;
+		}
+		break;
+
+	case hwmon_temp:
+		/* temp1_input: NTC temperature in millidegrees */
+		if (attr == hwmon_temp_input) {
+			*val = (long)priv->ntc.temp_c * 1000;
+			return 0;
+		}
+		break;
+
+	default:
+		break;
+	}
+
+	return -EOPNOTSUPP;
+}
+
+static const struct hwmon_channel_info * const hy310_hwmon_info[] = {
+	HWMON_CHANNEL_INFO(fan,  HWMON_F_INPUT),
+	HWMON_CHANNEL_INFO(pwm,  HWMON_PWM_INPUT),
+	HWMON_CHANNEL_INFO(temp, HWMON_T_INPUT),
+	NULL,
+};
+
+static const struct hwmon_ops hy310_hwmon_ops = {
+	.is_visible = hy310_hwmon_is_visible,
+	.read       = hy310_hwmon_read,
+};
+
+static const struct hwmon_chip_info hy310_hwmon_chip = {
+	.ops  = &hy310_hwmon_ops,
+	.info = hy310_hwmon_info,
+};
+
+/* Reboot notifier removed: power-hold not used on HY310 (battery.enable=0) */
+
+/* -------------------------------------------------------------------------
+ * DTS parsing helpers
+ * ------------------------------------------------------------------------- */
+
+/**
+ * hy310_parse_ntc_table - parse gpadc-table or lradc-table from DTS
+ * @priv:  driver private data
+ * @node:  device node to search
+ *
+ * Tries "gpadc-table" first, then "lradc-table".
+ * Table format: flat array of u32 pairs <temp_decidegC adc_val ...>
+ * sorted descending by adc_val.
+ */
+static void hy310_parse_ntc_table(struct hy310_board_mgr *priv,
+				  struct device_node *node)
+{
+	const char *prop_names[] = { "gpadc-table", "lradc-table", NULL };
+	int pi;
+
+	for (pi = 0; prop_names[pi]; pi++) {
+		int len;
+		int num_u32;
+		int num_pairs;
+		int i;
+		const __be32 *prop;
+
+		prop = of_get_property(node, prop_names[pi], &len);
+		if (!prop)
+			continue;
+
+		num_u32 = len / sizeof(u32);
+		num_pairs = num_u32 / 2;
+
+		if (num_pairs == 0 || num_pairs > HY310_MAX_TABLE_ENTRIES) {
+			dev_warn(priv->dev,
+				 "NTC table '%s': ignoring (%d pairs, max %d)\n",
+				 prop_names[pi], num_pairs,
+				 HY310_MAX_TABLE_ENTRIES);
+			continue;
+		}
+
+		for (i = 0; i < num_pairs * 2; i++)
+			priv->ntc_table[i] = be32_to_cpup(prop + i);
+
+		priv->ntc_table_len = num_pairs;
+		dev_info(priv->dev, "NTC: loaded %d-entry table from '%s'\n",
+			 num_pairs, prop_names[pi]);
+		return;
+	}
+
+	dev_warn(priv->dev, "NTC: no temperature table found in DTS\n");
+}
+
+/**
+ * hy310_parse_fan_node - parse a single fan subnode (fan0, fan1, ...)
+ * @priv:    driver private data
+ * @fan_np:  fan subnode
+ * @idx:     fan index
+ * @period:  PWM period in nanoseconds (from parent node)
+ */
+static int hy310_parse_fan_node(struct hy310_board_mgr *priv,
+				struct device_node *fan_np, int idx,
+				u32 period)
+{
+	struct hy310_fan *fan = &priv->fans[idx];
+	struct device *dev = priv->dev;
+	int ret;
+	int num_u32;
+	u32 arr[HY310_MAX_MODES];
+
+	fan->period_ns = period;
+	atomic_set(&fan->fg_count, 0);
+	fan->fg_irq = -1;
+	fan->power_gpio = -EINVAL;
+	fan->fg_gpio = -EINVAL;
+
+	/* --- duty-array-policy1 --- */
+	num_u32 = of_property_count_u32_elems(fan_np, "duty-array-policy1");
+	if (num_u32 <= 0) {
+		dev_err(dev, "%s: missing duty-array-policy1\n",
+			fan_np->name);
+		return -EINVAL;
+	}
+	if (num_u32 > HY310_MAX_MODES)
+		num_u32 = HY310_MAX_MODES;
+
+	ret = of_property_read_u32_array(fan_np, "duty-array-policy1",
+					 arr, num_u32);
+	if (ret) {
+		dev_err(dev, "%s: failed to read duty-array-policy1: %d\n",
+			fan_np->name, ret);
+		return ret;
+	}
+
+	memcpy(fan->duty_array, arr, num_u32 * sizeof(u32));
+	fan->num_modes = num_u32;
+
+	/* Set initial duty from current mode (mode 0 at probe) */
+	fan->duty_pct = fan->duty_array[0];
+
+	/* --- fan-power-gpio --- */
+	fan->power_gpio = of_get_named_gpio(fan_np, "fan-power-gpio", 0);
+	if (gpio_is_valid(fan->power_gpio)) {
+		/*
+		 * Set fan power HIGH. Use gpio_request + gpio_direction_output
+		 * explicitly to ensure the pin is driven HIGH even after
+		 * rmmod/insmod cycles when the DTS gpio-hog is no longer active.
+		 */
+		ret = devm_gpio_request(dev, fan->power_gpio, "fan-power");
+		if (ret) {
+			/* Hog might still own it — just ensure it's HIGH */
+			dev_info(dev, "%s: fan-power-gpio %d (managed by hog)\n",
+				 fan_np->name, fan->power_gpio);
+		} else {
+			gpio_direction_output(fan->power_gpio, 1);
+			dev_info(dev, "%s: fan-power-gpio %d set HIGH\n",
+				 fan_np->name, fan->power_gpio);
+		}
+	}
+
+	/* --- fg-gpio (tachometer via direct DAT register polling) --- */
+	fan->fg_gpio = of_get_named_gpio(fan_np, "fg-gpio", 0);
+	if (gpio_is_valid(fan->fg_gpio)) {
+		/*
+		 * Do NOT request the GPIO through the GPIO subsystem!
+		 * On H713, gpio_request → pinctrl sets the pin to a function
+		 * that blocks the physical input (even function 0 through
+		 * pinctrl differs from the hardware reset state).
+		 * Instead, read the PIO DAT register directly via ioremap.
+		 */
+
+		/*
+		 * Set up direct DAT register access for hrtimer polling.
+		 * PIO base is ioremap'd once in probe; DAT offset per bank
+		 * is bank * 0x30 + 0x10 (H713 NEW_REG_LAYOUT).
+		 */
+		{
+			int gpio_num = fan->fg_gpio;
+			int bank = gpio_num / 32;
+			int pin = gpio_num % 32;
+			void __iomem *cfg_reg;
+			u32 cfg_val;
+			int cfg_idx = (pin % 8) * 4; /* 4 bits per pin in CFG register */
+
+			fan->fg_dat_reg = priv->pio_base + bank * 0x30 + 0x10;
+			fan->fg_dat_bit = BIT(pin);
+
+			/*
+			 * Set pin to function 0 (GPIO input) directly via PIO
+			 * CFG register. At boot, the pin may be in function 15
+			 * (disabled). We bypass the GPIO/pinctrl subsystem
+			 * because on H713 the pinctrl mux change can block the
+			 * physical input path for extended PH pins.
+			 */
+			cfg_reg = priv->pio_base + bank * 0x30 + (pin / 8) * 4;
+			cfg_val = readl(cfg_reg);
+			cfg_val &= ~(0xF << cfg_idx);
+			/* function 0 = gpio_in, no bits to set */
+			writel(cfg_val, cfg_reg);
+		}
+		fan->fg_last_val = (readl(fan->fg_dat_reg) & fan->fg_dat_bit) ? 1 : 0;
+		fan->fg_irq = -1; /* not using IRQ */
+
+		/* Start hrtimer for GPIO edge polling */
+		hrtimer_setup(&fan->fg_poll_timer, fg_poll_callback,
+			      CLOCK_MONOTONIC, HRTIMER_MODE_REL);
+		hrtimer_start(&fan->fg_poll_timer,
+			      ns_to_ktime(FG_POLL_INTERVAL_NS),
+			      HRTIMER_MODE_REL);
+
+		dev_info(dev, "%s: tachometer on GPIO %d (hrtimer polling)\n",
+			 fan_np->name, fan->fg_gpio);
+	}
+
+skip_tacho:
+	/* --- RPM warn thresholds --- */
+	if (of_property_read_u32(fan_np, "fg-warn-speed",
+				 &fan->rpm_warn_speed))
+		fan->rpm_warn_speed = DEFAULT_FG_WARN_SPEED;
+
+	if (of_property_read_u32(fan_np, "fg-warn-cnt",
+				 &fan->rpm_warn_cnt))
+		fan->rpm_warn_cnt = DEFAULT_FG_WARN_CNT;
+
+	fan->rpm_warn_cycles = 0;
+	fan->valid = true;
+
+	dev_info(dev, "fan%d: modes=%u, power_gpio=%d, fg_gpio=%d, fg_irq=%d\n",
+		 idx, fan->num_modes, fan->power_gpio, fan->fg_gpio,
+		 fan->fg_irq);
+	return 0;
+}
+
+/**
+ * hy310_acquire_pwm - get PWM device for fan at index @idx
+ * @priv:    driver private data
+ * @idx:     fan index
+ *
+ * Uses devm_pwm_get() with con_id "fan0"/"fan1"/... which requires
+ * a "pwms" phandle property or a "fan0" named PWM in the DTS node.
+ * Falls back to unnamed PWM (con_id=NULL) for single-fan setups.
+ */
+static struct pwm_device *hy310_acquire_pwm(struct hy310_board_mgr *priv,
+					    int idx)
+{
+	struct pwm_device *pwm;
+	char con_id[16];
+
+	/* Try named PWM: "fan0", "fan1", ... */
+	snprintf(con_id, sizeof(con_id), "fan%d", idx);
+	pwm = devm_pwm_get(priv->dev, con_id);
+	if (!IS_ERR(pwm))
+		return pwm;
+
+	/* Fallback: unnamed (first) PWM for fan index 0 */
+	if (idx == 0) {
+		pwm = devm_pwm_get(priv->dev, NULL);
+		if (!IS_ERR(pwm))
+			return pwm;
+	}
+
+	dev_warn(priv->dev, "PWM for fan%d not found: %ld\n",
+		 idx, PTR_ERR(pwm));
+	return NULL;
+}
+
+/* -------------------------------------------------------------------------
+ * Probe
+ * ------------------------------------------------------------------------- */
+
+static int hy310_board_mgr_probe(struct platform_device *pdev)
+{
+	struct device *dev = &pdev->dev;
+	struct device_node *np = dev->of_node;
+	struct hy310_board_mgr *priv;
+	struct device_node *child;
+	struct device_node *gpios_np;
+	struct device_node *ntc_np;
+	u32 pwm_ids[HY310_MAX_FANS];
+	int num_pwm_ids = 0;
+	u32 period_ns;
+	u32 fan_policy;
+	int fan_idx = 0;
+	int ret;
+	int i;
+
+	priv = devm_kzalloc(dev, sizeof(*priv), GFP_KERNEL);
+	if (!priv)
+		return -ENOMEM;
+
+	priv->dev = dev;
+	mutex_init(&priv->lock);
+	priv->usb_power_gpio = -EINVAL;
+	priv->current_mode = 0;
+
+	/* Map PIO registers for direct GPIO DAT reads (tachometer polling) */
+	priv->pio_base = ioremap(0x02000000, 0x400);
+	if (!priv->pio_base) {
+		dev_err(dev, "failed to ioremap PIO base\n");
+		return -ENOMEM;
+	}
+
+	platform_set_drvdata(pdev, priv);
+
+	/* ---- fan_policy: we only support policy 1 ---- */
+	if (of_property_read_u32(np, "fan_policy", &fan_policy)) {
+		dev_info(dev, "fan_policy not set, assuming 1\n");
+		fan_policy = 1;
+	}
+	if (fan_policy != 1) {
+		dev_err(dev, "unsupported fan_policy %u (only policy 1 implemented)\n",
+			fan_policy);
+		return -EINVAL;
+	}
+
+	/* ---- PWM period ---- */
+	if (of_property_read_u32(np, "pwm_period_ns", &period_ns))
+		period_ns = DEFAULT_PWM_PERIOD_NS;
+	dev_info(dev, "PWM period: %u ns\n", period_ns);
+
+	/* ---- pwm_ids: numeric PWM channel IDs ---- */
+	num_pwm_ids = of_property_count_u32_elems(np, "pwm_ids");
+	if (num_pwm_ids > 0) {
+		if (num_pwm_ids > HY310_MAX_FANS)
+			num_pwm_ids = HY310_MAX_FANS;
+		ret = of_property_read_u32_array(np, "pwm_ids",
+						 pwm_ids, num_pwm_ids);
+		if (ret) {
+			dev_err(dev, "failed to read pwm_ids: %d\n", ret);
+			return ret;
+		}
+		dev_info(dev, "pwm_ids: %d channels\n", num_pwm_ids);
+	} else {
+		num_pwm_ids = 0;
+	}
+
+	/* ---- Temperature thresholds ---- */
+	if (of_property_read_u32(np, "temp_poweroff", &priv->temp_poweroff_c))
+		priv->temp_poweroff_c = DEFAULT_TEMP_POWEROFF_C;
+	if (of_property_read_u32(np, "temp_warn", &priv->temp_warn_c))
+		priv->temp_warn_c = DEFAULT_TEMP_WARN_C;
+
+	/* ---- LRADC setup ---- */
+	priv->lradc_base = of_iomap(np, 0);
+	if (priv->lradc_base) {
+		priv->lradc_clk = of_clk_get(np, 0);
+		if (!IS_ERR(priv->lradc_clk)) {
+			ret = clk_prepare_enable(priv->lradc_clk);
+			if (ret) {
+				dev_warn(dev, "LRADC: clk_prepare_enable failed: %d\n",
+					 ret);
+				clk_put(priv->lradc_clk);
+				priv->lradc_clk = NULL;
+			}
+		} else {
+			dev_warn(dev, "LRADC: clock not available\n");
+			priv->lradc_clk = NULL;
+		}
+
+		priv->lradc_rst = devm_reset_control_get(dev, NULL);
+		if (!IS_ERR(priv->lradc_rst)) {
+			ret = reset_control_deassert(priv->lradc_rst);
+			if (ret)
+				dev_warn(dev, "LRADC: reset deassert failed: %d\n",
+					 ret);
+		} else {
+			dev_warn(dev, "LRADC: reset control not available\n");
+			priv->lradc_rst = NULL;
+		}
+
+		/* Initialize LRADC hardware */
+		writel(LRADC_CTRL_INIT, priv->lradc_base + LRADC_CTRL);
+		writel(LRADC_INTC_CH0_EN, priv->lradc_base + LRADC_INTC);
+		dev_info(dev, "LRADC initialized at %p\n", priv->lradc_base);
+	} else {
+		dev_warn(dev, "LRADC: no reg mapping, NTC disabled\n");
+	}
+
+	/* ---- NTC table ---- */
+	hy310_parse_ntc_table(priv, np);
+
+	/* ---- ntc subnode: check if NTC is enabled ---- */
+	ntc_np = of_get_child_by_name(np, "ntc");
+	if (ntc_np) {
+		u32 ntc_num = 0;
+		struct device_node *ntc0_np;
+
+		of_property_read_u32(ntc_np, "ntc_num", &ntc_num);
+
+		/*
+		 * Tolerant parsing: stock DTS has ntc_num=0 but ntc0.enable=1.
+		 * We treat this as "1 NTC enabled" if ntc0.enable == 1.
+		 */
+		ntc0_np = of_get_child_by_name(ntc_np, "ntc0");
+		if (ntc0_np) {
+			u32 ntc0_en = 0;
+
+			of_property_read_u32(ntc0_np, "enable", &ntc0_en);
+			if (ntc0_en == 1 || ntc_num > 0) {
+				priv->ntc.enabled = true;
+				dev_info(dev, "NTC enabled (ntc_num=%u, ntc0.enable=%u)\n",
+					 ntc_num, ntc0_en);
+			}
+			of_node_put(ntc0_np);
+		} else if (ntc_num > 0) {
+			priv->ntc.enabled = true;
+			dev_info(dev, "NTC enabled (ntc_num=%u)\n", ntc_num);
+		}
+
+		of_node_put(ntc_np);
+	}
+
+	/* ---- gpios subnode: USB power GPIO ---- */
+	gpios_np = of_get_child_by_name(np, "gpios");
+	if (gpios_np) {
+		priv->usb_power_gpio = of_get_named_gpio(
+			gpios_np, "usb-power-gpio", 0);
+
+		if (gpio_is_valid(priv->usb_power_gpio)) {
+			ret = devm_gpio_request_one(dev, priv->usb_power_gpio,
+						    GPIOF_OUT_INIT_HIGH,
+						    "usb-power");
+			if (ret) {
+				dev_warn(dev,
+					 "usb-power-gpio request failed: %d\n",
+					 ret);
+				priv->usb_power_gpio = -EINVAL;
+			} else {
+				dev_info(dev, "USB power GPIO %d enabled\n",
+					 priv->usb_power_gpio);
+			}
+		}
+		of_node_put(gpios_np);
+	}
+
+	/* battery subnode: skipped — battery.enable=0 on HY310, power-hold
+	 * shares PL3 with usb-power-gpio and is not relevant for this board. */
+
+	/* ---- fan subnodes: fan0, fan1, ... ---- */
+	for_each_child_of_node(np, child) {
+		if (!of_node_name_prefix(child, "fan"))
+			continue;
+		/* Skip the "fans" parent if DTS has one (not expected here) */
+		if (strncmp(child->name, "fan", 3) != 0)
+			continue;
+		/* Only accept "fan" + digit subnodes */
+		if (strlen(child->name) < 4 ||
+		    !isdigit(child->name[3]))
+			continue;
+
+		if (fan_idx >= HY310_MAX_FANS) {
+			dev_warn(dev, "too many fan subnodes, ignoring %s\n",
+				 child->name);
+			continue;
+		}
+
+		ret = hy310_parse_fan_node(priv, child, fan_idx, period_ns);
+		if (ret) {
+			dev_warn(dev, "fan%d parse failed: %d\n",
+				 fan_idx, ret);
+			continue;
+		}
+
+		/* Acquire PWM for this fan */
+		priv->fans[fan_idx].pwm = hy310_acquire_pwm(priv, fan_idx);
+		if (!priv->fans[fan_idx].pwm)
+			dev_warn(dev, "fan%d: no PWM device, speed control disabled\n",
+				 fan_idx);
+
+		fan_idx++;
+	}
+	priv->num_fans = fan_idx;
+
+	if (priv->num_fans == 0)
+		dev_warn(dev, "no fan subnodes found, fan control disabled\n");
+
+	/* ---- Apply initial PWM duties (mode 0) ---- */
+	mutex_lock(&priv->lock);
+	hy310_update_all_fan_duties(priv);
+	mutex_unlock(&priv->lock);
+
+	/* ---- Register thermal cooling device ---- */
+	if (priv->num_fans > 0) {
+		priv->cdev = devm_thermal_of_cooling_device_register(
+			dev, np, "hy310-fan", priv, &hy310_cooling_ops);
+		if (IS_ERR(priv->cdev)) {
+			dev_warn(dev, "thermal cooling device registration failed: %ld\n",
+				 PTR_ERR(priv->cdev));
+			priv->cdev = NULL;
+		} else {
+			dev_info(dev, "thermal cooling device registered\n");
+		}
+	}
+
+	/* ---- Register hwmon device ---- */
+	priv->hwmon_dev = devm_hwmon_device_register_with_info(
+		dev, "hy310_board_mgr", priv, &hy310_hwmon_chip, NULL);
+	if (IS_ERR(priv->hwmon_dev)) {
+		dev_warn(dev, "hwmon registration failed: %ld\n",
+			 PTR_ERR(priv->hwmon_dev));
+		priv->hwmon_dev = NULL;
+	} else {
+		dev_info(dev, "hwmon device registered\n");
+	}
+
+	/* ---- Start periodic work ---- */
+	INIT_DELAYED_WORK(&priv->fan_work, hy310_fan_work_fn);
+	INIT_DELAYED_WORK(&priv->ntc_work, hy310_ntc_work_fn);
+
+	/* Start tacho work if at least one fan has tachometer (hrtimer or IRQ) */
+	for (i = 0; i < priv->num_fans; i++) {
+		if (priv->fans[i].valid && priv->fans[i].fg_dat_reg) {
+			schedule_delayed_work(
+				&priv->fan_work,
+				msecs_to_jiffies(FAN_TACHO_INTERVAL_MS));
+			break;
+		}
+	}
+
+	/* Start NTC work if LRADC is available and NTC is enabled */
+	if (priv->ntc.enabled && priv->lradc_base)
+		schedule_delayed_work(&priv->ntc_work,
+				      msecs_to_jiffies(NTC_POLL_INTERVAL_MS));
+
+	dev_info(dev, "HY310 board manager probed: %d fan(s), NTC %s\n",
+		 priv->num_fans,
+		 priv->ntc.enabled ? "enabled" : "disabled");
+	return 0;
+}
+
+static void hy310_board_mgr_remove(struct platform_device *pdev)
+{
+	struct hy310_board_mgr *priv = platform_get_drvdata(pdev);
+	int i;
+
+	/* Cancel hrtimers for tachometer polling */
+	for (i = 0; i < priv->num_fans; i++) {
+		if (gpio_is_valid(priv->fans[i].fg_gpio))
+			hrtimer_cancel(&priv->fans[i].fg_poll_timer);
+	}
+
+	cancel_delayed_work_sync(&priv->fan_work);
+	cancel_delayed_work_sync(&priv->ntc_work);
+
+	/* Do NOT disable fan power on unload — GPIO hog keeps it running.
+	 * Cutting fan power risks thermal damage to the projector. */
+
+	/* PWMs are devm-managed, no manual free needed */
+
+	if (priv->lradc_clk) {
+		clk_disable_unprepare(priv->lradc_clk);
+		clk_put(priv->lradc_clk);
+	}
+
+	if (priv->lradc_base)
+		iounmap(priv->lradc_base);
+
+	if (priv->pio_base)
+		iounmap(priv->pio_base);
+}
+
+/* Reboot notifier removed: power-hold not used on HY310 (battery.enable=0) */
+
+static int __maybe_unused hy310_board_mgr_suspend(struct device *dev)
+{
+	struct hy310_board_mgr *priv = dev_get_drvdata(dev);
+
+	cancel_delayed_work_sync(&priv->fan_work);
+	cancel_delayed_work_sync(&priv->ntc_work);
+	hy310_fan_power_en(priv, 0);
+
+	dev_info(dev, "suspended: fan power off\n");
+	return 0;
+}
+
+static int __maybe_unused hy310_board_mgr_resume(struct device *dev)
+{
+	struct hy310_board_mgr *priv = dev_get_drvdata(dev);
+	int i;
+
+	hy310_fan_power_en(priv, 1);
+
+	/* Restore PWM duties */
+	mutex_lock(&priv->lock);
+	hy310_update_all_fan_duties(priv);
+	mutex_unlock(&priv->lock);
+
+	/* Restart periodic work */
+	for (i = 0; i < priv->num_fans; i++) {
+		if (priv->fans[i].valid && priv->fans[i].fg_dat_reg) {
+			schedule_delayed_work(
+				&priv->fan_work,
+				msecs_to_jiffies(FAN_TACHO_INTERVAL_MS));
+			break;
+		}
+	}
+
+	if (priv->ntc.enabled && priv->lradc_base)
+		schedule_delayed_work(&priv->ntc_work,
+				      msecs_to_jiffies(NTC_POLL_INTERVAL_MS));
+
+	dev_info(dev, "resumed: fan power restored\n");
+	return 0;
+}
+
+static SIMPLE_DEV_PM_OPS(hy310_board_mgr_pm_ops,
+			  hy310_board_mgr_suspend,
+			  hy310_board_mgr_resume);
+
+/* -------------------------------------------------------------------------
+ * Platform driver registration
+ * ------------------------------------------------------------------------- */
+
+static const struct of_device_id hy310_board_mgr_of_match[] = {
+	{ .compatible = "allwinner,hy310-board-mgr" },
+	/*
+	 * Fallback match for stock DTS using "pwm-fan" compatible:
+	 * Only bind if the HY310-specific "pwm_ids" property is present.
+	 * This is enforced in probe() — if pwm_ids is absent we return -ENODEV
+	 * so the mainline pwm-fan driver can claim the node instead.
+	 */
+	{ .compatible = "pwm-fan" },
+	{ /* sentinel */ }
+};
+MODULE_DEVICE_TABLE(of, hy310_board_mgr_of_match);
+
+/**
+ * hy310_is_hy310_node - check if a DTS node is really an HY310 board-mgr
+ *
+ * When matching via the generic "pwm-fan" compatible we must verify that
+ * HY310-specific properties are present to avoid stealing nodes that belong
+ * to the mainline pwm-fan driver.
+ */
+static bool hy310_is_hy310_node(struct device_node *np)
+{
+	/* "pwm_ids" is HY310-specific; mainline pwm-fan uses "pwms" phandle */
+	return of_property_present(np, "pwm_ids");
+}
+
+static int hy310_board_mgr_probe_check(struct platform_device *pdev)
+{
+	struct device_node *np = pdev->dev.of_node;
+	const struct of_device_id *match;
+
+	match = of_match_node(hy310_board_mgr_of_match, np);
+	if (match && strcmp(match->compatible, "pwm-fan") == 0) {
+		if (!hy310_is_hy310_node(np)) {
+			dev_dbg(&pdev->dev,
+				"pwm-fan node without pwm_ids, not an HY310 node\n");
+			return -ENODEV;
+		}
+		dev_info(&pdev->dev,
+			 "matched via 'pwm-fan' compatible with HY310 properties\n");
+	}
+
+	return hy310_board_mgr_probe(pdev);
+}
+
+static struct platform_driver hy310_board_mgr_driver = {
+	.probe    = hy310_board_mgr_probe_check,
+	.remove   = hy310_board_mgr_remove,
+	.driver   = {
+		.name           = "hy310-board-mgr",
+		.of_match_table = hy310_board_mgr_of_match,
+		.pm             = &hy310_board_mgr_pm_ops,
+	},
+};
+
+module_platform_driver(hy310_board_mgr_driver);
+
+MODULE_LICENSE("GPL");
+MODULE_DESCRIPTION("HY310 Projector Board Management Driver");
+MODULE_AUTHOR("HY310-DEV");
+MODULE_ALIAS("platform:hy310-board-mgr");
