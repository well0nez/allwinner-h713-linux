+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Allwinner H713 R_PIO pin controller driver
+ *
+ * Copyright (C) 2024 Project HY310
+ *
+ * The H713 R-domain pinctrl controls the PL and PM GPIO banks.
+ * Register layout uses the "new" (D1-style) 0x30-byte bank spacing,
+ * matching the main PIO on this SoC. Confirmed by stock driver
+ * decompilation (hw_type=1, bank_mem_size=0x30) and live register
+ * dumps (PM_CFG0 at base+0x30, PM_DAT at base+0x40).
+ *
+ * Pin function assignments derived from:
+ * - Stock DTS analysis (sun50iw12p1 r-pinctrl@7022000)
+ * - Live register dumps from HY310 hardware
+ * - Comparison with H6 R_PIO (similar architecture)
+ *
+ * PL bank functions (from stock DTS + register analysis):
+ *   PL0:  gpio, s_rsb_scl/s_twi_scl (fn2/fn3), PL_EINT0 (fn6)
+ *   PL1:  gpio, s_rsb_sda/s_twi_sda (fn2/fn3), PL_EINT1 (fn6)
+ *   PL2:  gpio, s_uart_tx (fn2), PL_EINT2 (fn6)
+ *   PL3:  gpio, s_uart_rx (fn2), PL_EINT3 (fn6)
+ *   PL4:  gpio, s_jtag_ms (fn2), PL_EINT4 (fn6)
+ *   PL5:  gpio, s_jtag_ck (fn2), PL_EINT5 (fn6)
+ *   PL6:  gpio, s_pwm0 (fn2), s_jtag_do (fn3), PL_EINT6 (fn6)
+ *   PL7:  gpio, s_pwm1 (fn2), s_jtag_di (fn3), PL_EINT7 (fn6)
+ *   PL8:  gpio, s_pwm2 (fn2), PL_EINT8 (fn6)
+ *   PL9:  gpio, s_cir (fn3), PL_EINT9 (fn6)
+ *   PL10: gpio, s_twi0_scl (fn2), PL_EINT10 (fn6)
+ *   PL11: gpio, s_twi0_sda (fn2), PL_EINT11 (fn6)
+ *   PL12: gpio, s_twi1_scl (fn2), PL_EINT12 (fn6)
+ *   PL13: gpio, s_twi1_sda (fn2), PL_EINT13 (fn6)
+ *   PL14: gpio, s_twi2_scl (fn2), PL_EINT14 (fn6)
+ *   PL15: gpio, s_twi2_sda (fn2), PL_EINT15 (fn6)
+ *
+ * PM bank functions (from stock DTS GPIO references):
+ *   PM0-PM4: gpio, PL_EINT (fn6) — used for WLAN/BT control
+ */
+
+#include <linux/init.h>
+#include <linux/platform_device.h>
+#include <linux/of.h>
+#include <linux/pinctrl/pinctrl.h>
+
+#include "pinctrl-sunxi.h"
+
+static const struct sunxi_desc_pin sun50i_h713_r_pins[] = {
+	/* PL0: s_rsb/s_i2c clock */
+	SUNXI_PIN(SUNXI_PINCTRL_PIN(L, 0),
+		  SUNXI_FUNCTION(0x0, "gpio_in"),
+		  SUNXI_FUNCTION(0x1, "gpio_out"),
+		  SUNXI_FUNCTION(0x2, "s_rsb"),		/* SCK */
+		  SUNXI_FUNCTION(0x3, "s_i2c"),		/* SCK */
+		  SUNXI_FUNCTION_IRQ_BANK(0x6, 0, 0)),	/* PL_EINT0 */
+	/* PL1: s_rsb/s_i2c data */
+	SUNXI_PIN(SUNXI_PINCTRL_PIN(L, 1),
+		  SUNXI_FUNCTION(0x0, "gpio_in"),
+		  SUNXI_FUNCTION(0x1, "gpio_out"),
+		  SUNXI_FUNCTION(0x2, "s_rsb"),		/* SDA */
+		  SUNXI_FUNCTION(0x3, "s_i2c"),		/* SDA */
+		  SUNXI_FUNCTION_IRQ_BANK(0x6, 0, 1)),	/* PL_EINT1 */
+	/* PL2: s_uart TX */
+	SUNXI_PIN(SUNXI_PINCTRL_PIN(L, 2),
+		  SUNXI_FUNCTION(0x0, "gpio_in"),
+		  SUNXI_FUNCTION(0x1, "gpio_out"),
+		  SUNXI_FUNCTION(0x2, "s_uart"),	/* TX */
+		  SUNXI_FUNCTION_IRQ_BANK(0x6, 0, 2)),	/* PL_EINT2 */
+	/* PL3: s_uart RX */
+	SUNXI_PIN(SUNXI_PINCTRL_PIN(L, 3),
+		  SUNXI_FUNCTION(0x0, "gpio_in"),
+		  SUNXI_FUNCTION(0x1, "gpio_out"),
+		  SUNXI_FUNCTION(0x2, "s_uart"),	/* RX */
+		  SUNXI_FUNCTION_IRQ_BANK(0x6, 0, 3)),	/* PL_EINT3 */
+	/* PL4: s_jtag MS */
+	SUNXI_PIN(SUNXI_PINCTRL_PIN(L, 4),
+		  SUNXI_FUNCTION(0x0, "gpio_in"),
+		  SUNXI_FUNCTION(0x1, "gpio_out"),
+		  SUNXI_FUNCTION(0x2, "s_jtag"),	/* MS */
+		  SUNXI_FUNCTION_IRQ_BANK(0x6, 0, 4)),	/* PL_EINT4 */
+	/* PL5: s_jtag CK */
+	SUNXI_PIN(SUNXI_PINCTRL_PIN(L, 5),
+		  SUNXI_FUNCTION(0x0, "gpio_in"),
+		  SUNXI_FUNCTION(0x1, "gpio_out"),
+		  SUNXI_FUNCTION(0x2, "s_jtag"),	/* CK */
+		  SUNXI_FUNCTION_IRQ_BANK(0x6, 0, 5)),	/* PL_EINT5 */
+	/* PL6: s_pwm0 / s_jtag DO */
+	SUNXI_PIN(SUNXI_PINCTRL_PIN(L, 6),
+		  SUNXI_FUNCTION(0x0, "gpio_in"),
+		  SUNXI_FUNCTION(0x1, "gpio_out"),
+		  SUNXI_FUNCTION(0x2, "s_pwm0"),
+		  SUNXI_FUNCTION(0x3, "s_jtag"),	/* DO */
+		  SUNXI_FUNCTION_IRQ_BANK(0x6, 0, 6)),	/* PL_EINT6 */
+	/* PL7: s_pwm1 / s_jtag DI */
+	SUNXI_PIN(SUNXI_PINCTRL_PIN(L, 7),
+		  SUNXI_FUNCTION(0x0, "gpio_in"),
+		  SUNXI_FUNCTION(0x1, "gpio_out"),
+		  SUNXI_FUNCTION(0x2, "s_pwm1"),
+		  SUNXI_FUNCTION(0x3, "s_jtag"),	/* DI */
+		  SUNXI_FUNCTION_IRQ_BANK(0x6, 0, 7)),	/* PL_EINT7 */
+	/* PL8: s_pwm2 */
+	SUNXI_PIN(SUNXI_PINCTRL_PIN(L, 8),
+		  SUNXI_FUNCTION(0x0, "gpio_in"),
+		  SUNXI_FUNCTION(0x1, "gpio_out"),
+		  SUNXI_FUNCTION(0x2, "s_pwm2"),
+		  SUNXI_FUNCTION_IRQ_BANK(0x6, 0, 8)),	/* PL_EINT8 */
+	/* PL9: s_cir (IR receiver, mux 3 from IDA) */
+	SUNXI_PIN(SUNXI_PINCTRL_PIN(L, 9),
+		  SUNXI_FUNCTION(0x0, "gpio_in"),
+		  SUNXI_FUNCTION(0x1, "gpio_out"),
+		  SUNXI_FUNCTION(0x3, "s_cir"),
+		  SUNXI_FUNCTION_IRQ_BANK(0x6, 0, 9)),	/* PL_EINT9 */
+	/* PL10: s_twi0 SCL */
+	SUNXI_PIN(SUNXI_PINCTRL_PIN(L, 10),
+		  SUNXI_FUNCTION(0x0, "gpio_in"),
+		  SUNXI_FUNCTION(0x1, "gpio_out"),
+		  SUNXI_FUNCTION(0x2, "s_twi0"),	/* SCL */
+		  SUNXI_FUNCTION_IRQ_BANK(0x6, 0, 10)),	/* PL_EINT10 */
+	/* PL11: s_twi0 SDA */
+	SUNXI_PIN(SUNXI_PINCTRL_PIN(L, 11),
+		  SUNXI_FUNCTION(0x0, "gpio_in"),
+		  SUNXI_FUNCTION(0x1, "gpio_out"),
+		  SUNXI_FUNCTION(0x2, "s_twi0"),	/* SDA */
+		  SUNXI_FUNCTION_IRQ_BANK(0x6, 0, 11)),	/* PL_EINT11 */
+	/* PL12: s_twi1 SCL */
+	SUNXI_PIN(SUNXI_PINCTRL_PIN(L, 12),
+		  SUNXI_FUNCTION(0x0, "gpio_in"),
+		  SUNXI_FUNCTION(0x1, "gpio_out"),
+		  SUNXI_FUNCTION(0x2, "s_twi1"),	/* SCL */
+		  SUNXI_FUNCTION_IRQ_BANK(0x6, 0, 12)),	/* PL_EINT12 */
+	/* PL13: s_twi1 SDA */
+	SUNXI_PIN(SUNXI_PINCTRL_PIN(L, 13),
+		  SUNXI_FUNCTION(0x0, "gpio_in"),
+		  SUNXI_FUNCTION(0x1, "gpio_out"),
+		  SUNXI_FUNCTION(0x2, "s_twi1"),	/* SDA */
+		  SUNXI_FUNCTION_IRQ_BANK(0x6, 0, 13)),	/* PL_EINT13 */
+	/* PL14: s_twi2 SCL */
+	SUNXI_PIN(SUNXI_PINCTRL_PIN(L, 14),
+		  SUNXI_FUNCTION(0x0, "gpio_in"),
+		  SUNXI_FUNCTION(0x1, "gpio_out"),
+		  SUNXI_FUNCTION(0x2, "s_twi2"),	/* SCL */
+		  SUNXI_FUNCTION_IRQ_BANK(0x6, 0, 14)),	/* PL_EINT14 */
+	/* PL15: s_twi2 SDA */
+	SUNXI_PIN(SUNXI_PINCTRL_PIN(L, 15),
+		  SUNXI_FUNCTION(0x0, "gpio_in"),
+		  SUNXI_FUNCTION(0x1, "gpio_out"),
+		  SUNXI_FUNCTION(0x2, "s_twi2"),	/* SDA */
+		  SUNXI_FUNCTION_IRQ_BANK(0x6, 0, 15)),	/* PL_EINT15 */
+	/* Hole between PL and PM */
+	/* PM0: GPIO (WLAN hostwake on HY310) */
+	SUNXI_PIN(SUNXI_PINCTRL_PIN(M, 0),
+		  SUNXI_FUNCTION(0x0, "gpio_in"),
+		  SUNXI_FUNCTION(0x1, "gpio_out"),
+		  SUNXI_FUNCTION_IRQ_BANK(0x6, 1, 0)),	/* PM_EINT0 */
+	/* PM1: GPIO (WLAN regon on HY310) */
+	SUNXI_PIN(SUNXI_PINCTRL_PIN(M, 1),
+		  SUNXI_FUNCTION(0x0, "gpio_in"),
+		  SUNXI_FUNCTION(0x1, "gpio_out"),
+		  SUNXI_FUNCTION_IRQ_BANK(0x6, 1, 1)),	/* PM_EINT1 */
+	/* PM2: GPIO (BT wake on HY310) */
+	SUNXI_PIN(SUNXI_PINCTRL_PIN(M, 2),
+		  SUNXI_FUNCTION(0x0, "gpio_in"),
+		  SUNXI_FUNCTION(0x1, "gpio_out"),
+		  SUNXI_FUNCTION_IRQ_BANK(0x6, 1, 2)),	/* PM_EINT2 */
+	/* PM3: GPIO (BT hostwake on HY310) */
+	SUNXI_PIN(SUNXI_PINCTRL_PIN(M, 3),
+		  SUNXI_FUNCTION(0x0, "gpio_in"),
+		  SUNXI_FUNCTION(0x1, "gpio_out"),
+		  SUNXI_FUNCTION_IRQ_BANK(0x6, 1, 3)),	/* PM_EINT3 */
+	/* PM4: GPIO (BT reset on HY310) */
+	SUNXI_PIN(SUNXI_PINCTRL_PIN(M, 4),
+		  SUNXI_FUNCTION(0x0, "gpio_in"),
+		  SUNXI_FUNCTION(0x1, "gpio_out"),
+		  SUNXI_FUNCTION_IRQ_BANK(0x6, 1, 4)),	/* PM_EINT4 */
+};
+
+static const struct sunxi_pinctrl_desc sun50i_h713_r_pinctrl_data = {
+	.pins = sun50i_h713_r_pins,
+	.npins = ARRAY_SIZE(sun50i_h713_r_pins),
+	.pin_base = PL_BASE,
+	.irq_banks = 2,
+	.io_bias_cfg_variant = BIAS_VOLTAGE_PIO_POW_MODE_SEL,
+};
+
+static int sun50i_h713_r_pinctrl_probe(struct platform_device *pdev)
+{
+	return sunxi_pinctrl_init_with_flags(pdev,
+					     &sun50i_h713_r_pinctrl_data,
+					     SUNXI_PINCTRL_NEW_REG_LAYOUT);
+}
+
+static const struct of_device_id sun50i_h713_r_pinctrl_match[] = {
+	{ .compatible = "allwinner,sun50i-h713-r-pinctrl", },
+	{}
+};
+
+static struct platform_driver sun50i_h713_r_pinctrl_driver = {
+	.probe	= sun50i_h713_r_pinctrl_probe,
+	.driver	= {
+		.name		= "sun50i-h713-r-pinctrl",
+		.of_match_table	= sun50i_h713_r_pinctrl_match,
+	},
+};
+builtin_platform_driver(sun50i_h713_r_pinctrl_driver);
